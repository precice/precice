<?xml version="1.0" encoding="UTF-8" ?>
<precice-configuration experimental="on">
  <data:vector name="VelocityLike" />
  <data:scalar name="PressureLike" />

  <mesh name="Mesh2D" dimensions="3">
    <use-data name="VelocityLike" />
    <use-data name="PressureLike" />
  </mesh>

  <mesh name="Mesh3D" dimensions="3">
    <use-data name="VelocityLike" />
    <use-data name="PressureLike" />
  </mesh>

  <participant name="Fluid2D">
    <provide-mesh name="Mesh2D" />
    <receive-mesh name="Mesh3D" from="Fluid3D" />
    <mapping:axial-geometric-multiscale
      direction="read"
      multiscale-dimension="2d-3d"
      multiscale-type="collect"
      multiscale-radius="1.0"
      multiscale-axis="z"
      from="Mesh3D"
      to="Mesh2D"
      constraint="consistent" />
    <write-data name="PressureLike" mesh="Mesh2D" />
    <read-data name="VelocityLike" mesh="Mesh2D" />
  </participant>

  <participant name="Fluid3D">
    <receive-mesh name="Mesh2D" from="Fluid2D" />
    <provide-mesh name="Mesh3D" />
    <mapping:axial-geometric-multiscale
      direction="read"
      multiscale-dimension="2d-3d"
      multiscale-type="spread"
      multiscale-radius="1.0"
      multiscale-axis="z"
      multiscale-cross-section-profile="parabolic"
      multiscale-cross-section="square"
      from="Mesh2D"
      to="Mesh3D"
      constraint="consistent" />
    <write-data name="VelocityLike" mesh="Mesh3D" />
    <read-data name="PressureLike" mesh="Mesh3D" />
  </participant>

  <m2n:sockets acceptor="Fluid2D" connector="Fluid3D" />

  <coupling-scheme:serial-explicit>
    <participants first="Fluid2D" second="Fluid3D" />
    <max-time-windows value="5" />
    <time-window-size value="1.0" />
    <exchange data="PressureLike" mesh="Mesh2D" from="Fluid2D" to="Fluid3D" />
    <exchange data="VelocityLike" mesh="Mesh3D" from="Fluid3D" to="Fluid2D" initialize="on" />
  </coupling-scheme:serial-explicit>
</precice-configuration>
